---
layout: layouts/base.njk
title: Tutorials — Learn Marker
description: Step-by-step guides for every part of Marker — from a casual round with your group to running a full tournament.
---

<section class="page-hero">
  <div class="container">
    <h1>Tutorials</h1>
    <p>Step-by-step guides for every part of Marker — from a round with your group to running a full tournament.</p>
  </div>
</section>

<section class="section section--white tutorials-index">
  <div class="container">

    {% set gettingStartedTutorials = collections.tutorials | tutorialsByPath("getting-started") %}
    {% set groupTutorials = collections.tutorials | tutorialsByPath("group") %}
    {% set eventTutorials = collections.tutorials | tutorialsByPath("event") %}
    {% set refTutorials   = collections.tutorials | tutorialsByPath("reference") %}

    <!-- ── Getting Started ───────────────────────────────────── -->
    <div class="tutorial-category">
      <div class="tutorial-category__header">
        <div class="tutorial-category__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
          Getting Started
        </div>
        <h2>New to Marker? Start here.</h2>
        <p>Sign in, set up your profile, and choose how you want to play.</p>
      </div>
      {% if gettingStartedTutorials | length %}
      <div class="tutorial-grid">
        {% for tut in gettingStartedTutorials %}
        <a href="{{ tut.url | url }}" class="tutorial-card" aria-label="{{ tut.data.title }} tutorial">
          <div class="tutorial-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              {{ tut.data.iconSvg | safe }}
            </svg>
          </div>
          <h3 class="tutorial-card__title">{{ tut.data.title }}</h3>
          <p class="tutorial-card__desc">{{ tut.data.cardDescription }}</p>
          <span class="tutorial-card__time">{{ tut.data.estimatedTime }}</span>
        </a>
        {% endfor %}
      </div>
      {% else %}
      <p class="tutorial-coming-soon">Tutorials for this path are coming soon.</p>
      {% endif %}
    </div>

    <!-- ── Playing with Your Group ───────────────────────────── -->
    <div class="tutorial-category">
      <div class="tutorial-category__header">
        <div class="tutorial-category__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 17l4-4 4 4 4-6 4 3"/>
            <circle cx="5" cy="6" r="2"/>
            <line x1="5" y1="8" x2="5" y2="14"/>
          </svg>
          Playing with Your Group
        </div>
        <h2>Create a scorecard and play.</h2>
        <p>For a single group or foursome — create a scorecard, add players, set up games, and settle up when the round ends.</p>
      </div>
      {% if groupTutorials | length %}
      <div class="tutorial-grid">
        {% for tut in groupTutorials %}
        <a href="{{ tut.url | url }}" class="tutorial-card" aria-label="{{ tut.data.title }} tutorial">
          <div class="tutorial-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              {{ tut.data.iconSvg | safe }}
            </svg>
          </div>
          <h3 class="tutorial-card__title">{{ tut.data.title }}</h3>
          <p class="tutorial-card__desc">{{ tut.data.cardDescription }}</p>
          <span class="tutorial-card__time">{{ tut.data.estimatedTime }}</span>
        </a>
        {% endfor %}
      </div>
      {% else %}
      <p class="tutorial-coming-soon">Tutorials for this path are coming soon.</p>
      {% endif %}
    </div>

    <!-- ── Running an Event ──────────────────────────────────── -->
    <div class="tutorial-category">
      <div class="tutorial-category__header">
        <div class="tutorial-category__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Running an Event
        </div>
        <h2>From field setup to final settlement.</h2>
        <p>For commissioners organizing multiple groups — create the event, build the field, set up scorecards and games, then publish and settle.</p>
      </div>
      {% if eventTutorials | length %}
      <div class="tutorial-grid">
        {% for tut in eventTutorials %}
        <a href="{{ tut.url | url }}" class="tutorial-card" aria-label="{{ tut.data.title }} tutorial">
          <div class="tutorial-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              {{ tut.data.iconSvg | safe }}
            </svg>
          </div>
          <h3 class="tutorial-card__title">{{ tut.data.title }}</h3>
          <p class="tutorial-card__desc">{{ tut.data.cardDescription }}</p>
          <span class="tutorial-card__time">{{ tut.data.estimatedTime }}</span>
        </a>
        {% endfor %}
      </div>
      {% else %}
      <p class="tutorial-coming-soon">Tutorials for this path are coming soon.</p>
      {% endif %}
    </div>

    <!-- ── Learn More ────────────────────────────────────────── -->
    <div class="tutorial-category">
      <div class="tutorial-category__header">
        <div class="tutorial-category__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          Learn More
        </div>
        <h2>Reference guides and advanced features.</h2>
        <p>Account setup, handicap configuration, side games, and AI-powered game creation.</p>
      </div>
      {% if refTutorials | length %}
      <div class="tutorial-grid">
        {% for tut in refTutorials %}
        <a href="{{ tut.url | url }}" class="tutorial-card" aria-label="{{ tut.data.title }} tutorial">
          <div class="tutorial-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              {{ tut.data.iconSvg | safe }}
            </svg>
          </div>
          <h3 class="tutorial-card__title">{{ tut.data.title }}</h3>
          <p class="tutorial-card__desc">{{ tut.data.cardDescription }}</p>
          <span class="tutorial-card__time">{{ tut.data.estimatedTime }}</span>
        </a>
        {% endfor %}
      </div>
      {% else %}
      <p class="tutorial-coming-soon">Tutorials for this path are coming soon.</p>
      {% endif %}
    </div>

  </div>
</section>

<!-- CTA band -->
<section class="cta-band">
  <div class="container">
    <h2>Ready to play?</h2>
    <p>Start a round in under a minute.</p>
    <div class="cta-band__actions">
      <a href="https://app.marker.golf" class="btn btn-primary">Try Marker Free</a>
    </div>
  </div>
</section>
