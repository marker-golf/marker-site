---
layout: layouts/base.njk
title: Tutorials — Learn Marker
description: Step-by-step guides for getting started with Marker and running every supported golf game format.
---

<section class="page-hero">
  <div class="container">
    <h1>Tutorials</h1>
    <p>Step-by-step guides for every part of Marker — from your first event to running a Ryder Cup.</p>
  </div>
</section>

<section class="section section--white tutorials-index">
  <div class="container">

    <!-- ── Getting Started ───────────────────────────────── -->
    <div class="tutorial-category">
      <div class="tutorial-category__header">
        <div class="tutorial-category__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          Getting Started
        </div>
        <h2>New to Marker? Start here.</h2>
        <p>Learn how to create an account, set up your first event, and run a round from start to finish.</p>
      </div>
      <div class="tutorial-grid">
        {% for tut in collections.tutorials %}
        {% if tut.data.category == "Getting Started" %}
        <a href="{{ tut.url | url }}" class="tutorial-card" aria-label="{{ tut.data.title }} tutorial">
          <div class="tutorial-card__media" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              {{ tut.data.iconSvg | safe }}
            </svg>
          </div>
          <div class="tutorial-card__body">
            <span class="tutorial-card__time">{{ tut.data.estimatedTime }}</span>
            <h3 class="tutorial-card__title">{{ tut.data.title }}</h3>
            <p class="tutorial-card__desc">{{ tut.data.cardDescription }}</p>
          </div>
        </a>
        {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- ── Running Events ─────────────────────────────────── -->
    <div class="tutorial-category">
      <div class="tutorial-category__header">
        <div class="tutorial-category__label">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          Running Events
        </div>
        <h2>From game setup to final settlement.</h2>
        <p>Step-by-step guides for running events — adding games, configuring handicaps, scoring, and settling up.</p>
      </div>
      <div class="tutorial-grid">

        {% for tut in collections.tutorials %}
        {% if tut.data.category == "Running Events" %}
        <a href="{{ tut.url | url }}" class="tutorial-card" aria-label="{{ tut.data.title }} tutorial">
          <div class="tutorial-card__media" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              {{ tut.data.iconSvg | safe }}
            </svg>
          </div>
          <div class="tutorial-card__body">
            <span class="tutorial-card__time">{{ tut.data.estimatedTime }}</span>
            <h3 class="tutorial-card__title">{{ tut.data.title }}</h3>
            <p class="tutorial-card__desc">{{ tut.data.cardDescription }}</p>
          </div>
        </a>
        {% endif %}
        {% endfor %}

      </div>
    </div>

  </div>
</section>

<!-- CTA band -->
<section class="cta-band">
  <div class="container">
    <h2>Ready to play?</h2>
    <p>Start a round in under a minute.</p>
    <div class="cta-band__actions">
      <a href="https://app.marker.golf" class="btn btn-primary">Try Marker Free</a>
    </div>
  </div>
</section>
