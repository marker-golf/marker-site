---
layout: layouts/base.njk
title: Golf Games
description: Marker supports the most popular golf side games — from Skins and Nassau to Wolf, Nines, and team formats. Set them up before you tee off and Marker handles all the math.
---

{% from "components/badges.njk" import AppStoreBadge, PlayStoreBadge %}

<section class="page-hero">
  <div class="container">
    <h1>Every game. Zero math.</h1>
    <p>From classic formats like Skins and Nassau to games built for serious golf trips and multi-group events, Marker handles the scoring so you can focus on the game.</p>
  </div>
</section>

<section class="section section--white">
  <div class="container">

    <!-- ── Featured Games ─────────────────────────────────── -->
    <div class="games-section">
      <div class="games-section-header">
        <h2>Featured Games</h2>
        <p>Marker's signature formats — more strategy, more drama, more fun.</p>
      </div>
      <div class="game-grid">
        {% for game in collections.games %}
        {% if game.data.category == "featured" %}
        <a href="{{ game.url | url }}" class="game-card game-card--featured game-card--link">
          <span class="game-badge {% if game.data.status == 'available' %}game-badge--available{% else %}game-badge--soon{% endif %}">{% if game.data.status == "available" %}Available in Marker{% else %}Coming Soon{% endif %}</span>
          <h3>{{ game.data.game.name }}</h3>
          <p>{{ game.data.cardDescription }}</p>
          <span class="game-card__cta">Learn about {{ game.data.game.name }} →</span>
        </a>
        {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- ── Classic Formats ────────────────────────────────── -->
    <div class="games-section">
      <div class="games-section-header">
        <h2>Classic Formats</h2>
        <p>The games every golfer knows — now with automatic scoring, live leaderboards, and instant settlement.</p>
      </div>
      <div class="game-grid">
        {% for game in collections.games %}
        {% if game.data.category == "classic" %}
        <a href="{{ game.url | url }}" class="game-card game-card--link">
          <span class="game-badge {% if game.data.status == 'available' %}game-badge--available{% else %}game-badge--soon{% endif %}">{% if game.data.status == "available" %}Available in Marker{% else %}Coming Soon{% endif %}</span>
          <h3>{{ game.data.game.name }}</h3>
          <p>{{ game.data.cardDescription }}</p>
          <span class="game-card__cta">Learn about {{ game.data.game.name }} →</span>
        </a>
        {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<!-- CTA band -->
<section class="cta-band">
  <div class="container">
    <h2>Ready to play?</h2>
    <p>Start a round in under a minute. Available on iPhone, iPad, Android, and Web.</p>
    <div class="cta-band__actions">
      <a href="https://app.marker.golf" class="btn btn-primary">Try Marker Free</a>
      <div class="cta-band__badges">
        {{ AppStoreBadge() }}
        {{ PlayStoreBadge() }}
      </div>
    </div>
  </div>
</section>
