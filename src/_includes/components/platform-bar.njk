{% macro PlatformSupportBar() %}
<div class="platform-bar" aria-label="Platform availability">
  <div class="platform-bar__item platform-bar__item--usga">
    <img src="{{ '/images/usga-badge.png' | url }}" alt="USGA Handicap Data Affiliate" class="platform-bar__usga-badge">
    <span class="platform-bar__label">Official USGA<br>Handicap Affiliate</span>
  </div>
  <div class="platform-bar__divider" aria-hidden="true"></div>
  <div class="platform-bar__item">
    <svg class="platform-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="5" y="2" width="14" height="20" rx="2"/>
      <circle cx="12" cy="17" r="1" fill="currentColor" stroke="none"/>
    </svg>
    <span class="platform-bar__label">iPhone &amp; iPad</span>
  </div>
  <div class="platform-bar__item">
    <svg class="platform-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
      <path d="M6.343 17.657 4.929 19.07M19.07 4.93l-1.414 1.414M16 12h4M4 12h4M17.657 17.657l-1.414-1.414M6.343 6.343 4.929 4.929"/>
    </svg>
    <span class="platform-bar__label">Android</span>
  </div>
  <div class="platform-bar__item">
    <svg class="platform-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span class="platform-bar__label">Web Access</span>
  </div>
</div>
{% endmacro %}
