<footer class="site-footer">
  <div class="container">
    <div class="footer__grid">

      <div class="footer__brand">
        <a href="{{ '/' | url }}" class="footer__logo" aria-label="Marker home">
          <img src="{{ '/images/MarkerLogo.svg' | url }}" alt="Marker">
        </a>
        <p>The golf scoring app for groups. Track scores live, manage side games, and settle up instantly.</p>
        <div class="footer__social">
          <a href="https://www.instagram.com/markergolfapp" aria-label="Marker on Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@markergolfapp" aria-label="Marker on YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h5>Product</h5>
        <ul>
          <li><a href="{{ '/' | url }}">Home</a></li>
          <li><a href="{{ '/games/' | url }}">Games</a></li>
          <li><a href="{{ '/commissioners/' | url }}">For Leagues</a></li>
          <li><a href="{{ '/about/' | url }}">About</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h5>Games</h5>
        <ul>
          {% for game in collections.games %}
          {% if game.data.status == 'available' %}
          <li><a href="{{ game.url | url }}">{{ game.data.game.name }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="footer__col">
        <h5>Learn</h5>
        <ul>
          <li><a href="{{ '/tutorials/getting-started/' | url }}">Getting Started</a></li>
          <li><a href="{{ '/tutorials/create-an-event/' | url }}">Create an Event</a></li>
          <li><a href="{{ '/tutorials/add-and-configure-games/' | url }}">Add and Configure Games</a></li>
          <li><a href="{{ '/tutorials/handicap-settings/' | url }}">Using Handicaps in Marker</a></li>
          <li><a href="{{ '/tutorials/ai-game-generation/' | url }}">AI Game Generation</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h5>Support</h5>
        <ul>
          <li><a href="{{ '/tutorials/' | url }}">All Tutorials</a></li>
          <li><a href="mailto:info@marker.golf">info@marker.golf</a></li>
        </ul>
      </div>

    </div>
    <div class="footer__bottom">
      <span>© 2026 Marker Golf</span>
      <div class="footer__legal">
        <a href="{{ '/terms/' | url }}">Terms</a>
        <a href="{{ '/privacy/' | url }}">Privacy</a>
      </div>
    </div>
  </div>
</footer>
