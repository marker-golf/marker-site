<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | Marker Golf{% else %}Marker Golf — All Golf. No Math.{% endif %}</title>
  <meta name="description" content="{{ description or 'Marker is the golf scoring app for groups. Score live, manage side games, and settle up instantly. Available on iPhone, iPad, Android, and Web.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
</head>
<body>
  {% include "header.njk" %}
  <main>{{ content | safe }}</main>
  {% include "footer.njk" %}
  <script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
