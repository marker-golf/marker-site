---
layout: layouts/base.njk
---

{% if tutorialPath == "group" %}
  {% set pathLabel = "Playing with Your Group" %}
{% elif tutorialPath == "event" %}
  {% set pathLabel = "Running an Event" %}
{% else %}
  {% set pathLabel = "Learn More" %}
{% endif %}

{% set pathNav = collections.tutorials | prevNextInPath(page.url, tutorialPath) %}

<section class="tutorial-hero">
  <div class="container">
    <nav class="tutorial-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ '/tutorials/' | url }}">Tutorials</a>
      <span aria-hidden="true">›</span>
      <span>{{ pathLabel }}</span>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{{ title }}</span>
    </nav>
    <h1>{{ title }}</h1>
    <p>{{ subtitle }}</p>
    <nav class="tutorial-subnav" aria-label="Tutorial navigation">
      <span class="tutorial-subnav__path">{{ pathLabel }}{% if pathNav.totalSteps > 1 %} · {{ pathNav.currentStep }} of {{ pathNav.totalSteps }}{% endif %}</span>
      {% if pathNav.prev %}
      <a href="{{ pathNav.prev.url | url }}">← {{ pathNav.prev.data.title }}</a>
      {% endif %}
      {% if pathNav.next %}
      <a href="{{ pathNav.next.url | url }}">{{ pathNav.next.data.title }} →</a>
      {% endif %}
      <a href="{{ '/tutorials/' | url }}">All tutorials</a>
    </nav>
  </div>
</section>

<section class="section section--white">
  <div class="container">

    {{ content | safe }}

    <div class="tutorial-footer-nav">
      {% if pathNav.next %}
      <span class="tutorial-footer-nav__label">Up next</span>
      <a href="{{ pathNav.next.url | url }}" class="btn btn-primary btn-sm">{{ pathNav.next.data.title }} →</a>
      {% endif %}
      <a href="{{ '/tutorials/' | url }}" class="btn btn-ghost btn-sm">All Tutorials</a>
    </div>

  </div>
</section>

<section class="cta-band">
  <div class="container">
    <h2>{{ cta.heading }}</h2>
    <p>{{ cta.body }}</p>
    <div class="cta-band__actions">
      <a href="https://app.marker.golf" class="btn btn-primary">Open Marker</a>
    </div>
  </div>
</section>
