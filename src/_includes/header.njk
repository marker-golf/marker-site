<header class="site-header">
  <div class="container">
    <nav class="nav" aria-label="Main navigation">
      <a href="{{ '/' | url }}" class="nav__logo" aria-label="Marker home">
        <img src="{{ '/images/MarkerLogo.svg' | url }}" alt="Marker" width="46" height="44">
      </a>
      <ul class="nav__links" role="list">
        <li>
          <a href="{{ '/games/' | url }}"{% if '/games' in page.url %} aria-current="page"{% endif %}>Games</a>
        </li>
        <li>
          <a href="{{ '/commissioners/' | url }}"{% if '/commissioners' in page.url %} aria-current="page"{% endif %}>For Leagues</a>
        </li>
      </ul>
      <img src="{{ '/images/usga-badge.png' | url }}" alt="USGA Handicap Data Affiliate" class="nav__usga-badge">
      <button class="nav__toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>
  <div class="nav__mobile" id="mobile-nav" hidden>
    <ul role="list">
      <li><a href="{{ '/' | url }}"{% if page.url == '/' %} aria-current="page"{% endif %}>Home</a></li>
      <li><a href="{{ '/games/' | url }}"{% if '/games' in page.url %} aria-current="page"{% endif %}>Games</a></li>
      <li><a href="{{ '/commissioners/' | url }}"{% if '/commissioners' in page.url %} aria-current="page"{% endif %}>For Leagues</a></li>
      <li><a href="{{ '/about/' | url }}"{% if '/about' in page.url %} aria-current="page"{% endif %}>About</a></li>
    </ul>
    <a href="https://app.marker.golf" class="btn btn-primary nav__mobile-cta">Try Marker Free</a>
  </div>
</header>
